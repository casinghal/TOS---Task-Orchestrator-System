# .env.example - PracticeIQ
# Copy this to .env.local and fill in real values for local development.
# Real Supabase values come from the project provisioned in Mumbai
# (per D-2026-04-30-15 reconciliation; first migration already applied).
# Never commit .env.local. See MASTER_PROJECT.md Section 15 for the full
# deployment env-var contract; same five keys are set on Netlify.

# --- Database ---
# Pooled Postgres connection (port 6543, pgbouncer). Used by app at runtime.
DATABASE_URL=postgres://postgres:<password>@<host>:6543/postgres?pgbouncer=true&connection_limit=1

# Direct (unpooled) Postgres connection. Used by `prisma migrate` for
# advisory locks and CREATE INDEX operations that pgbouncer cannot handle.
# Same Supabase host as DATABASE_URL but port 5432 (direct) instead of 6543.
DIRECT_URL=postgres://postgres:<password>@<host>:5432/postgres

# --- Supabase Auth (Section 14 Step 4) ---
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<public-anon-key>

# Server-only secret for privileged Supabase admin operations
# (RLS bypass, service-role API calls). Never expose in client code,
# never commit to git, never add to NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
